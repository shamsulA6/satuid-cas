# ============================================================
# CAS Authentication — Perbendaharaan Malaysia
# Salin baris-baris ini ke dalam fail .env anda
# ============================================================

# Toggle CAS: true = SATUID, false = Laravel standard (dev tempatan)
CAS_ENABLED=true

# CAS Server (SATUID)
CAS_HOSTNAME=satuid.treasury.gov.my
CAS_PORT=443
CAS_URI=/gk

# URL aplikasi anda — MESTI didaftarkan di SATUID terlebih dahulu
CAS_CLIENT_SERVICE=https://app-anda.treasury.gov.my

# Redirect selepas login berjaya
CAS_REDIRECT_PATH=/dashboard

# Logout
CAS_LOGOUT_URL=https://satuid.treasury.gov.my/gk/logout
CAS_LOGOUT_REDIRECT=https://app-anda.treasury.gov.my

# Endpoint validasi ticket
CAS_VALIDATE_PATH=/gk/serviceValidate

# SSL: 'ca' untuk production, 'none' untuk development
CAS_VALIDATION=ca
